export component RightIcon {
    width: 24px;
    height: 24px;

    in property <brush> fill: #FFF;

    callback clicked();

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => root.clicked();
    }

    RightIconArrow {
        fill: root.fill;
    }

    RightIconBox {
        x: ta.has-hover ? (round(mod(animation-tick(), 1s) / 1s) * 3px) + 4px : 3px;
        fill: root.fill;

        animate x {
            duration: 1000ms;
            easing: ease-out-elastic;
        }
    }
}

