component PauseIconBox inherits Path {
    in property <float> right-top-offset-x;
    in property <float> right-top-offset-y;

    in property <float> right-bottom-offset-x;
    in property <float> right-bottom-offset-y;

    in property <float> left-bottom-offset-x;
    in property <float> left-bottom-offset-y;

    in property <float> left-top-offset-x;
    in property <float> left-top-offset-y;

    viewbox-width: 12;
    viewbox-height: 18;

    fill: #FFF;

    MoveTo {
        x: right-top-offset-x;
        y: right-top-offset-y;
    }

    CubicTo {
        control-1-x: right-top-offset-x + 0.26;
        control-1-y: right-top-offset-y;
        control-2-x: right-top-offset-x + 0.51;
        control-2-y: right-top-offset-y + 0.10;
        x: right-top-offset-x + 0.70;
        y: right-top-offset-y + 0.29;
    }

    CubicTo {
        control-1-x: right-top-offset-x + 0.89;
        control-1-y: right-top-offset-y + 0.48;
        control-2-x: right-top-offset-x + 1;
        control-2-y: right-top-offset-y + 0.73;
        x: right-top-offset-x + 1;
        y: right-top-offset-y + 1;
    }

    LineTo {
        x: right-bottom-offset-x + 1;
        y: right-bottom-offset-y;
    }

    CubicTo {
        control-1-x: right-bottom-offset-x + 1;
        control-1-y: right-bottom-offset-y + 0.26;
        control-2-x: right-bottom-offset-x + 0.89;
        control-2-y: right-bottom-offset-y + 0.51;
        x: right-bottom-offset-x + 0.70;
        y: right-bottom-offset-y + 0.70;
    }

    CubicTo {
        control-1-x: right-bottom-offset-x + 0.51;
        control-1-y: right-bottom-offset-y + 0.89;
        control-2-x: right-bottom-offset-x + 0.26;
        control-2-y: right-bottom-offset-y + 1;
        x: right-bottom-offset-x;
        y: right-bottom-offset-y + 1;
    }

    LineTo {
        x: left-bottom-offset-x + 1;
        y: left-bottom-offset-y + 1;
    }

    CubicTo {
        control-1-x: left-bottom-offset-x + 0.73;
        control-1-y: left-bottom-offset-y + 1;
        control-2-x: left-bottom-offset-x + 0.48;
        control-2-y: left-bottom-offset-y + 0.89;
        x: left-bottom-offset-x + 0.29;
        y: left-bottom-offset-y + 0.70;
    }

    CubicTo {
        control-1-x: left-bottom-offset-x + 0.10;
        control-1-y: left-bottom-offset-y + 0.51;
        control-2-x: left-bottom-offset-x + 0;
        control-2-y: left-bottom-offset-y + 0.26;
        x: left-bottom-offset-x + 0;
        y: left-bottom-offset-y;
    }

    LineTo {
        x: left-top-offset-x + 0;
        y: left-top-offset-y + 1;
    }

    CubicTo {
        control-1-x: left-top-offset-x + 0;
        control-1-y: left-top-offset-y + 0.73;
        control-2-x: left-top-offset-x + 0.10;
        control-2-y: left-top-offset-y + 0.48;
        x: left-top-offset-x + 0.29;
        y: left-top-offset-y + 0.29;
    }

    CubicTo {
        control-1-x: left-top-offset-x + 0.48;
        control-1-y: left-top-offset-y + 0.10;
        control-2-x: left-top-offset-x + 0.73;
        control-2-y: left-top-offset-y + 0;
        x: left-top-offset-x + 1;
        y: left-top-offset-y + 0;
    }

    Close { }
}

component PauseIconBoxLeft inherits PauseIconBox {
    in property <bool> is-collapsed: false;

    right-top-offset-x: is-collapsed ? 5.1 : 3;
    right-top-offset-y: is-collapsed ? 2.6 : 0;

    right-bottom-offset-x: is-collapsed ? 5.1 : 3;
    right-bottom-offset-y: is-collapsed ? 14.4 : 17;

    left-bottom-offset-x: is-collapsed ? -1.3 : 0;
    left-bottom-offset-y: is-collapsed ? 17 : 17;

    left-top-offset-x: is-collapsed ? -1.3 : 0;
    left-top-offset-y: is-collapsed ? 0 : 0;

    animate right-top-offset-x, right-top-offset-y, right-bottom-offset-x, right-bottom-offset-y, left-bottom-offset-x, left-bottom-offset-y, left-top-offset-x, left-top-offset-y { duration: 200ms; }
}

component PauseIconBoxRight inherits PauseIconBox {
    in property <bool> is-collapsed: false;

    right-top-offset-x: is-collapsed ? 5.1 : 3;
    right-top-offset-y: is-collapsed ? 7.8 : 0;

    right-bottom-offset-x: is-collapsed ? 5.1 : 3;
    right-bottom-offset-y: is-collapsed ? 9.2 : 17;

    left-bottom-offset-x: is-collapsed ? -2.8 : 0;
    left-bottom-offset-y: is-collapsed ? 14 : 17;

    left-top-offset-x: is-collapsed ? -2.8 : 0;
    left-top-offset-y: is-collapsed ? 3 : 0;

    animate right-top-offset-x, right-top-offset-y, right-bottom-offset-x, right-bottom-offset-y, left-bottom-offset-x, left-bottom-offset-y, left-top-offset-x, left-top-offset-y { duration: 200ms; }
}

component PauseIcon {
    in property <bool> is-collapsed: false;
    in property <brush> fill: #FFF;

    PauseIconBoxLeft {
        is-collapsed <=> root.is-collapsed;
        fill <=> root.fill;
    }

    PauseIconBoxRight {
        x: parent.width * 0.44;
        is-collapsed <=> root.is-collapsed;
        fill <=> root.fill;
    }
}

export component PlayPauseIcon {
    width: 28px;
    height: 28px;

    in property <bool> paused: true;
    in property <brush> fill: #FFF;

    callback clicked();

    pause := PauseIcon {
        width: parent.width;
        height: parent.width;
    }

    play := PlayIcon {
        width: parent.width;
        height: parent.width;
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => root.clicked();
    }

    states [
        paused when paused: {
            play.fill: fill.with-alpha(0);
            pause.fill: fill;
            out {
                animate play.fill {
                    duration: 170ms;
                    easing: cubic-bezier(1.0, 0, 0.84, 0);
                }
            }
        }
        playing when !paused: {
            pause.fill: fill.with-alpha(0);
            pause.is-collapsed: true;
            in {
                animate pause.fill {
                    duration: 200ms;
                    easing: cubic-bezier(1.0, 0, 0.84, 0);
                }
            }
        }
    ]
}
