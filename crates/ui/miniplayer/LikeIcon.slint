    commands: "M15 16h2.4a4 4 0 0 0 3.94-4.72l-.9-5A4 4 0 0 0 16.5 3H8v12l1.82 5.79c.3.69 1.06 1.31 2.02 1.13 1.53-.3 3.16-1.49 3.16-3.42zm-9-1a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z";
