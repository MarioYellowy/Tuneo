import { SongInfo } from "SongInfo.slint";
import { MiniPlayerState } from "State.slint";
import { PlaybackControls } from "PlaybackControls.slint";

export component MiniPlayer {
    height: 70px;

    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        alignment: center;

        HorizontalLayout {
            alignment: space-between;

            HorizontalLayout {
                width: 40%;

                SongInfo { }
            }

            HorizontalLayout {
                alignment: center;

                PlaybackControls { }
            }

            HorizontalLayout {
                width: 40%;
            }
        }
    }

    states [
        listening when MiniPlayerState.listening: {
            y: 0px;
            in {
                animate y {
                    duration: 200ms;
                    easing: ease-out;
                }
            }
        }
        not-listening when !MiniPlayerState.listening: {
            y: root.height;
            in {
                animate y {
                    duration: 200ms;
                    easing: ease-in;
                }
            }
        }
    ]
}
